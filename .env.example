# Environment Variables for Hamro Doctor Frontend

# Backend API URL
VITE_API_URL=http://localhost:5000

# API Version
VITE_API_VERSION=v1

# App Configuration
VITE_APP_NAME=Hamro Doctor
VITE_APP_DESCRIPTION=Your Health, Our Priority

# Feature Flags
VITE_ENABLE_SOCIAL_LOGIN=true
VITE_ENABLE_REGISTER=true

# For production, update these values:
# VITE_API_URL=https://api.hamrodoc.com
# VITE_APP_ENV=production
